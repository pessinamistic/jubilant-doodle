null, "contributor": null}, {"id": "docs_handover_port_wrangler_ai_appshell_jsx", "label": "AppShell.jsx (nav)", "file_type": "code", "source_file": "docs/HANDOVER-port-wrangler-ai.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_handover_port_wrangler_ai_agent_error_event", "label": "agent_error SSE event", "file_type": "rationale", "source_file": "docs/HANDOVER-port-wrangler-ai.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The agent SSE error event was renamed from 'error' to 'agent_error' because EventSource reserves the 'error' event name for connection failures \u2014 naming a server event 'error' collides with that reserved event."}, {"id": "docs_handover_port_wrangler_ai_infrastructuretools", "label": "InfrastructureTools", "file_type": "code", "source_file": "docs/HANDOVER-port-wrangler-ai.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_handover_port_wrangler_ai_agentsafety", "label": "AgentSafety", "file_type": "code", "source_file": "docs/HANDOVER-port-wrangler-ai.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AgentSafety.WRITE = {deployDatabase, createKafkaTopic, pullModel} is classified but NOT YET implemented in InfrastructureTools as of this handover \u2014 the single most natural next feature since it makes the north-star 'deploy X and give me config' sentence work end-to-end."}, {"id": "docs_handover_port_wrangler_ai_mcpserverconfig", "label": "McpServerConfig", "file_type": "code", "source_file": "docs/HANDOVER-port-wrangler-ai.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_handover_port_wrangler_ai_deploypipelineit", "label": "DeployPipelineIT", "file_type": "code", "source_file": "