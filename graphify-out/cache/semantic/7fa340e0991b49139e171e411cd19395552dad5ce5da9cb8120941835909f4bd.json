{"nodes": [{"id": "backend_docs_port_wrangler_roadmap_project_vision", "label": "Port Wrangler Project Vision", "file_type": "rationale", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Port Wrangler evolves from a Docker-based database deployer into a unified local infrastructure assistant so a developer never needs separate tools (DBeaver, kafka-ui, Ollama UI) or manual docker run commands; the AI assistant operates the stack directly."}, {"id": "backend_docs_port_wrangler_roadmap_final_architecture", "label": "Final Architecture (React + Spring Boot + Spring AI Layer)", "file_type": "concept", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "backend_docs_port_wrangler_roadmap_single_postgres_principle", "label": "Single PostgreSQL Instance For Everything", "file_type": "rationale", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "pgvector is added as an extension to the existing system Postgres rather than standing up a new vector store service, so there is one less thing for users to manage \u2014 zero-extra-service constraint."}, {"id": "backend_docs_port_wrangler_roadmap_existing_service_layer_as_ai_tools_principle", "label": "Existing Service Layer As AI Tools (No Dual Maintenance)", "file_type": "rationale", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "DbInstanceService, KafkaService, and AiRuntimeService are exposed as Spring AI @Tool methods with no new business logic, so the AI goes through the same code paths as the UI, avoiding dual maintenance."}, {"id": "backend_docs_port_wrangler_roadmap_sse_streaming_principle", "label": "SSE Streaming From Day One", "file_type": "rationale", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chat endpoint streams tokens starting in Phase 3 because getting SSE streaming infrastructure right once and reusing it forever beats retrofitting streaming later."}, {"id": "backend_docs_port_wrangler_roadmap_technology_stack", "label": "Final Technology Stack (Backend + Frontend)", "file_type": "document", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "backend_docs_port_wrangler_roadmap_flyway_migration_replace_ddl_auto", "label": "Replace ddl-auto with Flyway", "file_type": "rationale", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ddl-auto: update is fine for development but risky long-term; switching to Flyway with a baseline migration before adding new tables is non-negotiable and demonstrates database migration discipline."}, {"id": "backend_docs_port_wrangler_roadmap_kafka_schema_v2", "label": "V2 Kafka Instances/Topics Schema", "file_type": "document", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "backend_docs_port_wrangler_roadmap_ai_runtime_schema_v3", "label": "V3 AI Runtimes/Models Schema", "file_type": "document", "source_file": "backend/docs/port-wrangler-roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "backend_docs_port_wrangler_roadmap_pgvector_chat_schema_v4", "label": "V4 pgvector + Chat + RAG Documents Schema", "file_type": "